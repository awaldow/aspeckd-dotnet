<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--
      Multi-targeted to match every supported ASP.NET Core LTS/current release.
      TFM-specific or Microsoft.OpenApi-version-specific code can be added here
      using #if NET9_0_OR_GREATER / #if NET10_0_OR_GREATER guards as needed when
      Microsoft.OpenApi v1 → v2 → v3 breaking changes require different handling.
    -->
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Aspeckd</RootNamespace>
    <AssemblyName>Aspeckd</AssemblyName>
    <Description>
      ASP.NET Core integration for Aspeckd. Registers the agent spec endpoints and discovers
      API metadata via IApiDescriptionGroupCollectionProvider. TFM-specific and
      Microsoft.OpenApi-version-specific logic lives here, keeping Aspeckd.Core evergreen.
    </Description>
    <PackageTags>aspnet;aspnetcore;ai;agent;llm;api-spec;openapi</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <!--
      Pack the MSBuild targets file into the NuGet package so that consumers
      automatically get the GenerateAgentSpec and IncludeAgentSpecInPublish
      targets when they reference the Aspeckd package.
    -->
    <None Include="build/Aspeckd.targets" Pack="true" PackagePath="build/Aspeckd.targets" />
  </ItemGroup>

  <ItemGroup>
    <!--
      MinVer infers the NuGet package version from the nearest git tag
      (e.g. v1.2.3).  PrivateAssets="All" keeps it out of the published
      dependency graph.
    -->
    <PackageReference Include="MinVer" Version="6.0.0" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Asp.Versioning.Http provides IApiVersionDescriptionProvider, which Aspeckd uses
      to auto-detect API versions when the user calls AddApiVersioning() + AddApiExplorer().
      This is a soft dependency: the auto-detection only activates when
      IApiVersionDescriptionProvider is registered in the DI container; apps that do not
      use Asp.Versioning are unaffected.
    -->
    <PackageReference Include="Asp.Versioning.Http" Version="8.1.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Aspeckd.Core\Aspeckd.Core.csproj" />
  </ItemGroup>

</Project>

